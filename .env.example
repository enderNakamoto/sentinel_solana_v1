# Sentinel Solana — environment variables
# Copy to `.env.local` (frontend) and `.env` (executor) and fill in.

# ─── Frontend (Next.js) ───────────────────────────────────────────
# Public RPC + WebSocket endpoints exposed to the browser.
# Defaults below target Solana devnet. For local development against
# Surfpool, set both to http://127.0.0.1:8899 and ws://127.0.0.1:8900.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_WS_URL=wss://api.devnet.solana.com

# ─── Executor (off-chain crons) ───────────────────────────────────
# Server-side RPC. Same endpoint as the frontend in normal operation.
SOLANA_RPC_URL=https://api.devnet.solana.com

# Path to the executor keypair file. Used to sign oracle/keeper
# transactions in Phase 7+. The pubkey is committed at
# keys/executor.pubkey; the JSON is gitignored.
EXECUTOR_KEYPAIR=./keys/executor.json

# AeroAPI key (Phase 8+). Leave blank in Phase 0.
AERO_API_KEY=
