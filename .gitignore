# ─── Node ─────────────────────────────────────────────────────────
node_modules/
*.log
.pnpm-debug.log
.npm
.yarn

# ─── Anchor / Rust ────────────────────────────────────────────────
target/
.anchor/
**/*.rs.bk

# ─── Generated (regenerable from IDL/Codama) ──────────────────────
# NOTE: frontend/src/clients/ AND executor/src/clients/ are committed so
# Vercel (which lacks the Anchor toolchain) can run `next build` without
# a code-gen step. The frontend's API routes import from @executor/clients
# via the tsconfig path alias, so both must be present at build time.
# Regenerate locally with `pnpm gen-clients` after any contract change.
frontend/src/idl/
executor/src/idl/
contracts/tests/clients/
scripts/clients/
scripts/dist/
scripts/*.bundle.mjs
executor/src/scripts/dist/
executor/.env

# ─── Frontend (Next.js) ───────────────────────────────────────────
.next/
out/
frontend/.next/
frontend/out/
*.tsbuildinfo

# ─── Executor build output ────────────────────────────────────────
executor/dist/

# ─── Surfpool ─────────────────────────────────────────────────────
.surfpool/

# ─── Cron control panel (Phase 17) ───────────────────────────────
frontend/.cache-cron-runs.jsonl

# ─── Premium pricing agent (Phase 22) ────────────────────────────
agent/data/
# Trained model ships with the repo so the Render `sentinel-agent`
# service can boot without a build-time `make train` step. Regenerate
# locally with `make train` and re-commit when the model changes.
agent/artifacts/*
!agent/artifacts/model.joblib
!agent/artifacts/encoder.joblib
!agent/artifacts/feature_names.json
!agent/artifacts/model_version.txt
agent/__pycache__/
agent/**/__pycache__/
agent/.venv/
agent/.pytest_cache/
# Jupyter editing-state for agent/training/model_1.ipynb
.ipynb_checkpoints/
agent/**/.ipynb_checkpoints/

# ─── Env files (commit only .env.example) ─────────────────────────
.env
.env.local
.env.*.local

# ─── Keys (commit only the .pubkey side) ──────────────────────────
keys/*.json
keys/**/*.json

# ─── Deployment artifacts (cluster + timestamped JSON) ────────────
deployments/*.json
!deployments/.gitkeep

# ─── Editor / OS ──────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
