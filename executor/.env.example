# Sentinel executor (Phase 25) — env template
#
# Copy to `executor/.env` and fill in. Loaded by `dotenv/config` at the
# top of `src/scripts/run-cron.ts`. The Render deploy uses the same
# variable names — set them as `sync: false` secrets in the Render
# dashboard (see render.yaml at repo root).
#
# Never commit a real .env (it's gitignored at the repo root).

# ─── Required ─────────────────────────────────────────────────────────
CLUSTER=devnet
# Optional override — falls back to the deployment artifact's rpcUrl.
SOLANA_RPC_URL=https://api.devnet.solana.com

# One of CRON_KEEPER_BASE58 or KEEPER_KEYPAIR must be set.
# Production (Render): base58. Local dev: path to keys/<cluster>-deployer.json.
#
# The signer is used for ALL FOUR crons. In production, run
# `pnpm rotate-keeper` and `pnpm rotate-oracle` once so the deployer
# keypair becomes the authorized_keeper AND the authorized_oracle.
# CRON_KEEPER_BASE58=
KEEPER_KEYPAIR=keys/devnet-deployer.json

# ─── FlightAware AeroAPI (fetcher cron) ───────────────────────────────
# AEROAPI_KEY set → live mode by default. Without it, the fetcher
# requires `?mode=mock` on every trigger.
# AEROAPI_KEY=
# AEROAPI_MOCK=1
AEROAPI_MOCK_SCENARIO=on_time     # on_time | delayed | cancelled | scheduled | not_found

# ─── xAI Grok + Phase 22 agent (repricer cron) ────────────────────────
# XAI_API_KEY set → live Grok. AGENT_BASE_URL set → live agent. Either
# can be mocked independently with GROK_MOCK / AGENT_MOCK.
# XAI_API_KEY=
# AGENT_BASE_URL=http://localhost:8000
# AGENT_MOCK=1
AGENT_MOCK_PREMIUM_USDC=2.5
# GROK_MOCK=1
GROK_MOCK_VERDICT=ok              # ok | raise:1.5 | raise:2.0 | disable
# REPRICER_DRY_RUN=1               # decide actions but skip on-chain txs

# ─── HTTP server / auth ───────────────────────────────────────────────
HEALTH_PORT=8080
# Optional. When set, POST /api/trigger/* requires X-Trigger-Secret with
# this value. Frontend must hold the same secret in EXECUTOR_TRIGGER_SECRET.
# EXECUTOR_TRIGGER_SECRET=

# ─── Schedule overrides (optional) ────────────────────────────────────
# FETCHER_CRON=0 */2 * * *
# CLASSIFIER_CRON=0 * * * *
# SETTLER_CRON=*/5 * * * *
# REPRICER_CRON=0 0 * * *
# RUN_AT_BOOT=1                    # fire all 4 schedules once on startup
