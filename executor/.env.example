# Sentinel executor env — copy to executor/.env and fill in.
#
# Never commit a real .env (it's gitignored at the repo root).

# ─── Required for ALL crons ───────────────────────────────────────────
# Cluster name — must match a deployment artifact at deployments/<cluster>-latest.json.
# Phase 7's deploy script writes these (`pnpm run deploy --cluster <cluster> --owner <pk>`).
CLUSTER=surfpool

# Optional — overrides the deployment artifact's rpcUrl. Useful for staging.
# SOLANA_RPC_URL=http://127.0.0.1:8899

# ─── Phase 8 — FlightDataFetcher (oracle cron) ────────────────────────
# Path to the authorized_oracle keypair. Phase 7's deploy script
# auto-generates one at keys/<cluster>-oracle.json on first run.
ORACLE_KEYPAIR=keys/surfpool-oracle.json

# FlightAware AeroAPI key — passed in the `x-apikey` header.
# Get one at https://flightaware.com/aeroapi/portal/.
AEROAPI_KEY=

# Optional — overrides the AeroAPI base URL (https://aeroapi.flightaware.com/aeroapi).
# AEROAPI_BASE_URL=

# ─── Phase 9 + 10 — Classifier + Settler (controller crons) ──────────
# Path to the authorized_keeper keypair. Phase 7 generates one at
# keys/<cluster>-keeper.json by default.
KEEPER_KEYPAIR=keys/surfpool-keeper.json

# ─── Phase 10 — node-cron backend ─────────────────────────────────────
# Optional HTTP port for the /health endpoint. Default 8080.
# HEALTH_PORT=8080
