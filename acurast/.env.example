# Acurast deployment env. Acurast encrypts these at deploy time and
# decrypts them only inside the processor's TEE at runtime. They are
# accessed in-script via `_STD_.env.<KEY>`.
#
# Only the keys listed in each project's `includeEnvironmentVariables`
# field of acurast.json get shipped to that bundle.

# ─── Solana RPC ────────────────────────────────────────────────────
# JSON-RPC endpoint the TEE will POST to. Devnet is fine for the proof.
SOLANA_RPC_URL=https://api.devnet.solana.com

# ─── On-chain addresses (base58) ───────────────────────────────────
# Copy from deployments/devnet-latest.json in the parent repo. These are
# all public — committing them here is fine.
GOVERNANCE_PROGRAM_ID=6d6QXsZRQ1fXp8wEXFTm4uXAbLWarPKX6XJLcNUY8rcT
CONTROLLER_PROGRAM_ID=G4v4i3LoLX7v3cEb3cehNGWMHbvHArRyPSEiZmg5VSot
ORACLE_PROGRAM_ID=EmTfS5EjPRABDuDrM5AW5TWi73eCCJnejpLAcwaxMCr6
VAULT_PROGRAM_ID=3yzuTtfGYUBsdhXf4QGeq9MUGj5RDNLj3hFPtsWGkj8p
FLIGHT_POOL_PROGRAM_ID=GW1yq7rswXBect6yR1RWtU7Q7AmY5wWMnq58a1JGcwVq

# PDAs (v2 seeds — post-Phase-24 Token-2022 migration)
GOVERNANCE_CONFIG_PDA=AsVZzrc2ong7kU1bkfE4FM4q8mE5kVdRTa3pDW5yr74x
ORACLE_CONFIG_PDA=7FimnDxjyVw2T4cGR2fTv3vG1t5zS8iVEHBxNmR4J8xt
CONTROLLER_CONFIG_PDA=496TgyNMNYDoGgGmUEviJ2hvc9cvvf788sSn5WTsEKqw
ACTIVE_FLIGHTS_PDA=6Jisfz6sgbMZiCN2iKhjrkdRRTBwRyYLB4Tb4gFyJxJs

# ─── Off-chain APIs ────────────────────────────────────────────────
# FlightAware AeroAPI — fetcher only.
AEROAPI_KEY=

# Phase 22 pricing agent — repricer only.
AGENT_BASE_URL=https://sentinel-agent-solana.onrender.com

# xAI Grok — repricer only.
XAI_API_KEY=

# ─── Repricer safety toggle ────────────────────────────────────────
# Set to "1" to decide actions but skip on-chain txs.
REPRICER_DRY_RUN=1
