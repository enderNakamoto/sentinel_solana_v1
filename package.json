{
  "name": "sentinel-solana",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Decentralised flight delay insurance on Solana — monorepo root.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.9.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "sync-idl": "bash scripts/sync-idl.sh",
    "gen-clients": "node --experimental-strip-types scripts/gen-clients.ts",
    "dev:frontend": "pnpm --filter @sentinel/frontend dev",
    "dev:frontend:surfpool": "NEXT_PUBLIC_SOLANA_RPC_URL=http://127.0.0.1:8899 FAUCET_RPC_URL=http://127.0.0.1:8899 pnpm --filter @sentinel/frontend dev",
    "dev:executor": "pnpm --filter @sentinel/executor dev",
    "dev:surfpool": "bash scripts/dev-surfpool.sh",
    "test:contracts": "pnpm --filter @sentinel/contracts test",
    "test:integration": "pnpm --filter @sentinel/contracts test:integration",
    "test:integration:deployed": "pnpm --filter @sentinel/contracts test:integration:deployed",
    "test:e2e:crons": "pnpm --filter @sentinel/contracts test:e2e:crons",
    "deploy": "bash scripts/run.sh deploy",
    "fund-sol": "bash scripts/run.sh fund-sol",
    "fund-usdc": "bash scripts/run.sh fund-usdc",
    "seed-routes": "bash scripts/run.sh seed-routes",
    "bootstrap-test-actors": "bash scripts/run.sh bootstrap-test-actors",
    "run-fetcher": "bash scripts/run.sh run-fetcher",
    "run-classifier": "bash scripts/run.sh run-classifier",
    "run-settler": "bash scripts/run.sh run-settler",
    "cron-daemon": "bash scripts/run.sh run-cron",
    "build:all": "pnpm sync-idl && pnpm gen-clients && pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean && rm -rf contracts/target frontend/.next frontend/src/idl frontend/src/clients executor/dist executor/src/idl executor/src/clients .surfpool"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.4.1",
    "@codama/renderers-js": "^2.2.0",
    "@solana-program/system": "^0.12.0",
    "@solana-program/token": "^0.13.0",
    "@solana/kit": "^6.8.0",
    "@solana/kit-plugin-rpc": "^0.11.0",
    "@solana/kit-plugin-signer": "^0.10.0",
    "@solana/program-client-core": "^6.8.0",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.95.0",
    "@types/node": "^22.0.0",
    "codama": "^1.6.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
